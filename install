#!/bin/bash

cur="$(cd "$(dirname "$0")" && pwd)"
install="$cur/script/install.sh"

# 의존성 확인
check_dependencies() {
  echo "의존성 확인 중..."
  for cmd in git curl nvim; do
    if ! command -v $cmd &> /dev/null; then
      echo "오류: $cmd가 설치되어 있지 않습니다."
      exit 1
    fi
  done
  echo "모든 의존성이 설치되어 있습니다."
}

# 백업 생성
create_backup() {
  echo "기존 설정 백업 중..."
  BACKUP_DIR="$HOME/.config/backup_$(date +%Y%m%d%H%M%S)"
  mkdir -p "$BACKUP_DIR"

  if [ -d "$HOME/.config/nvim" ]; then
    cp -r "$HOME/.config/nvim" "$BACKUP_DIR/"
  fi

  echo "백업 완료: $BACKUP_DIR"
}

# 메인 설치 과정
main_install() {
  echo "스크립트 설치 중..."
  (cd script; $install ~/bin)

  echo "설정 파일 설치 중..."
  (cd settings; $install ~)

  echo "Neovim 설정 설치 중..."
  (mkdir -p ~/.config/nvim)
  (cd nvim; $install ~/.config/nvim)

  echo "SBT 설정 설치 중..."
  mkdir -p ~/.sbt/1.0
  for sbt_item in "$cur/sbt/1.0"/*; do
    [ -e "$sbt_item" ] || continue

    sbt_name="$(basename "$sbt_item")"
    if [ "$sbt_name" == "_recursive_" ]; then
      continue
    fi

    sbt_target="$HOME/.sbt/1.0/$sbt_name"
    if [ -L "$sbt_target" ] || [ -f "$sbt_target" ]; then
      rm -f "$sbt_target"
    elif [ -d "$sbt_target" ]; then
      rm -rf "$sbt_target"
    fi

    cp -R "$sbt_item" "$sbt_target"
  done

  echo "Git 설정 적용 중..."
  git config --global core.excludesfile ~/.gitignore_global

  echo "Neovim 플러그인 설치 중..."
  nvim --headless -c "Lazy sync" -c "qa"
}

# 메인 함수
main() {
  check_dependencies
  create_backup
  main_install
  echo "설치가 완료되었습니다!"
  echo "새 터미널을 열어 설정을 적용하세요."
}

# 실행
main
